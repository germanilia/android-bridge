<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Post-splash app theme -->
    <style name="Theme.AndroidBridge" parent="@android:style/Theme.Material.NoActionBar" />

    <!-- Splash screen theme (androidx core-splashscreen) -->
    <style name="Theme.AndroidBridge.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AndroidBridge</item>
    </style>
</resources>
